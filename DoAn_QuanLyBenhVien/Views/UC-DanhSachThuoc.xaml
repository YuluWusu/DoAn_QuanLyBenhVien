<UserControl x:Class="DoAn_QuanLyBenhVien.Views.UC_DanhSachThuoc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DoAn_QuanLyBenhVien.Views"
             xmlns:vm="clr-namespace:DoAn_QuanLyBenhVien.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1100" Background="#0F1923" HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch">
    <UserControl.DataContext>
        <vm:DanhSachThuocViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#1A2E45"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#1A2E45"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E3048"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" 
                BorderBrush="{TemplateBinding BorderBrush}" 
                BorderThickness="{TemplateBinding BorderThickness}" 
                CornerRadius="4">
                            <Grid x:Name="PART_Root">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox x:Name="PART_TextBox" 
                                   Grid.Column="0" 
                                   HorizontalContentAlignment="Stretch" 
                                   VerticalContentAlignment="Center" 
                                   Focusable="{TemplateBinding Focusable}"/>

                                <Button x:Name="PART_Button" Grid.Column="1" 
                        Background="Transparent" BorderThickness="0"
                        Foreground="#6B8299" Margin="2,0,5,0"
                        VerticalAlignment="Center">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>

                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" 
                       PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="txtDark" TargetType="TextBox">
            <Setter Property="Background" Value="#1A2E45"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E3048"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>
        
        <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="#00C2A8"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="15,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BtnGhost" TargetType="Button">
        <Setter Property="Background" Value="#1A2E45"/>
        <Setter Property="Foreground" Value="#6B8299"/>
        <Setter Property="BorderBrush" Value="#1E3048"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="15,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A2E45"/>
            <Setter Property="Foreground" Value="#6B8299"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="CboDark" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A2E45"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E3048"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          Foreground="{TemplateBinding Foreground}"
                          Grid.Column="2" Focusable="false"
                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                          ClickMode="Press">
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                              Margin="10,3,30,3" VerticalAlignment="Center" />
                            <TextBox Name="PART_EditableTextBox" Style="{x:Null}" 
                     HorizontalAlignment="Left" VerticalAlignment="Center" 
                     Margin="3,3,23,3" Focusable="True" Background="Transparent" 
                     Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>

                            <Path x:Name="Arrow" Fill="#6B8299" HorizontalAlignment="Right" 
                  VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L4,4 L8,0 Z" />

                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1A2E45" BorderThickness="1" BorderBrush="#1E3048"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridDark" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowBackground" Value="#15212F"/>
        <Setter Property="AlternatingRowBackground" Value="#1A2E45"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1E3048"/>
                    <Setter Property="Foreground" Value="#6B8299"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15" Orientation="Horizontal">
            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="#6B8299" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="DANH MỤC THUỐC" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Grid Width="200" Height="32">
                    <TextBox x:Name="txtSearch" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" 
                             Background="#1A2E45" Foreground="White" BorderBrush="#1E3048" Padding="8,0" FontSize="12"/>
                    <TextBlock IsHitTestVisible="False" Text="Tìm tên hoặc mã thuốc..." VerticalAlignment="Center" 
                               Margin="10,0,0,0" Foreground="#6B8299" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Button Command="{Binding SearchCommand}" Style="{StaticResource BtnGhost}" Width="65" Height="32" Margin="5,0,0,0" FontSize="11">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>
                        <TextBlock Text="TÌM" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Command="{Binding ThemCommand}" Style="{StaticResource BtnPrimary}" Width="100" Height="32" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>
                        <TextBlock Text="{Binding AddButtonText}" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding SuaCommand}" Style="{StaticResource BtnGhost}" Width="100" Height="32" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding EditButtonText}" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding XoaCommand}" Style="{StaticResource BtnGhost}" Foreground="#FF4C4C" Width="75" Height="32" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>
                        <TextBlock Text="XÓA" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding LuuCommand}" Style="{StaticResource BtnPrimary}" Background="#2D7FF9" Width="100" Height="32" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>
                        <TextBlock Text="LƯU LẠI" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <DataGrid ItemsSource="{Binding ListThuoc}" SelectedItem="{Binding SelectedItem}"  Grid.Row="2" Style="{StaticResource DataGridDark}" Margin="0,0,0,10" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="MÃ" Binding="{Binding MaThuoc}" Width="70"/>

                <DataGridTextColumn Header="TÊN THUỐC" Binding="{Binding TenThuoc}" Width="150"/>

                <DataGridTextColumn Header="ĐVT" Binding="{Binding DVT}" Width="60"/>

                <DataGridTextColumn Header="GIÁ NHẬP" Binding="{Binding GiaNhap, StringFormat={}{0:N0}đ}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="GIÁ BÁN" Binding="{Binding GiaBan, StringFormat={}{0:N0}đ}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="HẠN SD" Binding="{Binding HanSD, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>

                <DataGridTextColumn Header="HƯỚNG DẪN SỬ DỤNG" Binding="{Binding HuongDan}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="MaxHeight" Value="40"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#141E29" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <StackPanel>
                <TextBlock Text="THÔNG TIN CHI TIẾT THUỐC" Foreground="#00C2A8" FontWeight="Bold" Margin="5,0,0,15"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="10,5">
                        <TextBlock Text="Mã thuốc" Foreground="#6B8299" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtMaThuoc" Text="{Binding MaThuoc, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsAdding}" Height="32" Style="{StaticResource txtDark}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,5">
                        <TextBlock Text="Tên thuốc" Foreground="#6B8299" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtTenThuoc" Text="{Binding TenThuoc, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsInputEnabled}" Height="32" Style="{StaticResource txtDark}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,5">
                        <TextBlock Text="Hạn sử dụng" Foreground="#6B8299" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpHanSD" SelectedDate="{Binding HanSD}" IsEnabled="{Binding IsInputEnabled}" Height="32" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="10,5">
                        <TextBlock Text="Đơn vị tính" Foreground="#6B8299" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDVT" Text="{Binding DVT, UpdateSourceTrigger=PropertyChanged}" 
                                                 IsEnabled="{Binding IsInputEnabled}" Height="32" Style="{StaticResource txtDark}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="10,15,10,5">
                        <TextBlock Text="Giá nhập" Foreground="#6B8299" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtGiaNhap" Text="{Binding GiaNhap, UpdateSourceTrigger=LostFocus, StringFormat={}{0:N0}}" 
                                                     IsEnabled="{Binding IsInputEnabled}" Height="32" Style="{StaticResource txtDark}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,15,10,5">
                        <TextBlock Text="Giá bán" Foreground="#6B8299" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtGiaBan" Text="{Binding GiaBan, UpdateSourceTrigger=LostFocus, StringFormat={}{0:N0}}" 
                                                    IsEnabled="{Binding IsInputEnabled}" Height="32" Style="{StaticResource txtDark}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="10,15,10,5">
                        <TextBlock Text="Hướng dẫn sử dụng" Foreground="#6B8299" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtHuongDan" Text="{Binding HuongDan, UpdateSourceTrigger=PropertyChanged}" 
                                                      IsEnabled="{Binding IsInputEnabled}" Height="32" Style="{StaticResource txtDark}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
