<UserControl x:Class="DoAn_QuanLyBenhVien.Views.UC_PhieuXuatThuoc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DoAn_QuanLyBenhVien.Views"
             xmlns:vm="clr-namespace:DoAn_QuanLyBenhVien.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.DataContext>
        <vm:PhieuXuatThuocViewModel/>
    </UserControl.DataContext>
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Width="5" Height="30" Background="#00C2A8" CornerRadius="2" Margin="0,0,15,0"/>
            <TextBlock Text="PHIẾU XUẤT THUỐC" Foreground="White" FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#15212F" CornerRadius="15" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Ellipse Width="8" Height="8" Fill="#FFB800" Margin="0,0,8,0"/>
                        <TextBlock Text="DANH SÁCH CHỜ XUẤT" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0F1924" CornerRadius="8" Margin="0,0,0,20" Padding="10,5">
                        <Grid>
                            <TextBox x:Name="txtSearch" BorderThickness="0" Background="Transparent" Foreground="White" 
                                     CaretBrush="#00C2A8" VerticalContentAlignment="Center" Height="25" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Tìm mã đơn hoặc mã phiếu khám..." Foreground="#445566" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" Foreground="#6B8299" 
                                       HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                              ItemsSource="{Binding ListDonThuoc}" SelectedItem="{Binding SelectedDonThuoc}"
                              Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="Transparent"
                              BorderThickness="0" GridLinesVisibility="None"
                              RowHeight="45" HeadersVisibility="Column" Foreground="White">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#6B8299"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,5"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A2E45"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ ĐƠN" Binding="{Binding MaDonThuoc}" Width="90" FontWeight="Bold"/>
                            <DataGridTextColumn Header="MÃ PHIẾU KHÁM" Binding="{Binding MaPhieuKham}" Width="*"/>
                            <DataGridTextColumn Header="NGÀY KÊ" Binding="{Binding NgayKe, StringFormat='dd/MM/yyyy'}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#15212F" CornerRadius="15" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="CHI TIẾT THUỐC TRONG ĐƠN" Foreground="#00C2A8" FontWeight="Bold" Margin="0,0,0,15"/>

                        <DataGrid Grid.Row="1" AutoGenerateColumns="False" 
                                  Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="Transparent"
                                  BorderThickness="0" RowHeight="50" Foreground="White"
                                  ItemsSource="{Binding ListChiTietThuoc}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#1A2E45"/>
                                    <Setter Property="Foreground" Value="#6B8299"/>
                                    <Setter Property="Padding" Value="10"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TÊN THUỐC" Binding="{Binding TenThuoc}" Width="*"/>
                                <DataGridTextColumn Header="ĐVT" Binding="{Binding DVT}" Width="70"/>
                                <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="60"/>
                                <DataGridTextColumn Header="ĐƠN GIÁ" Binding="{Binding GiaBan, StringFormat={}{0:N0}}" Width="110"/>
                                <DataGridTextColumn Header="THÀNH TIỀN" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#00C2A8"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Setter Property="Margin" Value="0,0,10,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#15212F" CornerRadius="15" Padding="25,20" Margin="0,20,0,0">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TỔNG GIÁ TRỊ" Foreground="#6B8299" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} VNĐ}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Width="220" Height="55" BorderThickness="0" Cursor="Hand" Command="{Binding XuatKhoCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#00C2A8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="27">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#00E6C7"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#2A3F54"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="XÁC NHẬN XUẤT" Foreground="White" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
