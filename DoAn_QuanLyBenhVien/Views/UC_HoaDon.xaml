<UserControl x:Class="DoAn_QuanLyBenhVien.Views.UC_HoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DoAn_QuanLyBenhVien.Views"
             xmlns:vm="clr-namespace:DoAn_QuanLyBenhVien.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.DataContext>
        <vm:HoaDonViewModel/>
    </UserControl.DataContext>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#15212F" CornerRadius="15" Padding="15">
            <StackPanel>
                <TextBlock Text="DANH SÁCH CHỜ" Foreground="White" FontWeight="Bold" Margin="0,0,0,15"/>

                <Border Background="#0F1924" CornerRadius="8" Padding="10,5" Margin="0,0,0,15">
                    <Grid>
                        <TextBox x:Name="txtSearch" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         Foreground="White" 
                         CaretBrush="#00C2A8"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Tìm tên hoặc mã phiếu..." 
                           Foreground="#445566" 
                           IsHitTestVisible="False" 
                           VerticalAlignment="Center" 
                           Margin="5,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <DataGrid ItemsSource="{Binding ListHoaDon}" SelectedItem="{Binding SelectedHoaDon}"
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="Transparent" BorderThickness="0" 
                  GridLinesVisibility="None" Foreground="White">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1A2E45"/>
                            <Setter Property="Foreground" Value="#6B8299"/>
                            <Setter Property="Padding" Value="10,5"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#00C2A8"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MÃ PHIẾU" Binding="{Binding MA_PHIEUKHAM}" Width="100"/>
                        <DataGridTextColumn Header="BỆNH NHÂN" Binding="{Binding PHIEUKHAM.BENHNHAN.TEN_BENHNHAN}" Width="*"/>
                        <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding TRANGTHAI}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#15212F" CornerRadius="15" Margin="20,0,0,0" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="CHI TIẾT THANH TOÁN" Foreground="#00C2A8" FontWeight="Bold" FontSize="18"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding ListChiTiet}" 
          AutoGenerateColumns="False" 
          CanUserAddRows="False"
          Background="Transparent" 
          BorderThickness="0" 
          RowHeight="40"
          GridLinesVisibility="None"
          Foreground="White"
          SelectionUnit="FullRow">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1A2E45"/>
                            <Setter Property="Foreground" Value="#6B8299"/>
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#2D3D4F"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1F2D3D"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#00C2A8"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="LOẠI" Binding="{Binding Loai}" Width="100"/>
                        <DataGridTextColumn Header="TÊN ĐỐI TƯỢNG" Binding="{Binding MaDoiTuong}" Width="*"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="50"/>
                        <DataGridTextColumn Header="ĐƠN GIÁ" Binding="{Binding DonGia, StringFormat={}{0:N0}}" Width="100"/>
                        <DataGridTextColumn Header="THÀNH TIỀN" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2">
                    <Separator Background="#2D3D4F" Margin="0,10"/>
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TỔNG THANH TOÁN" Foreground="#6B8299" FontSize="12"/>
                            <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} VNĐ}" Foreground="#00C2A8" FontSize="32" FontWeight="Bold"/>
                        </StackPanel>

                        <Button Command="{Binding ThanhToanCommand}" 
            Content="XUẤT HÓA ĐƠN &amp; THU TIỀN"
            HorizontalAlignment="Right" 
            Width="250" Height="50" 
            BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#00C2A8"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#00E6C7"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#2D3D4F"/>
                                            <Setter Property="Foreground" Value="#6B8299"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
