<Window x:Class="DoAn_QuanLyBenhVien.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediClinic — Quản Lý Phòng Khám"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F1923">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>


        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#00C2A8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A8F7C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="#1A2E45"/>
            <Setter Property="Foreground"      Value="#6B8299"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#1E3048"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6B8299"/>
                                <Setter Property="Foreground" Value="#E2EAF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>


        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#6B8299"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="2,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="HeaderHost"
                                                  Grid.Column="0"
                                                  ContentSource="Header"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>

                                <Path x:Name="SubMenuArrow"
                                      Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 0 8 Z"
                                      Fill="#6B8299"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Visibility="Collapsed"/>

                                <Popup x:Name="PART_Popup"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border Background="#111D2B"
                                            BorderBrush="#1E3048"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="4">
                                        <ScrollViewer CanContentScroll="True"
                                                      Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubMenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A2E45"/>
                                <Setter Property="Foreground" Value="#E2EAF3"/>
                                <Setter TargetName="SubMenuArrow" Property="Fill" Value="#E2EAF3"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0E2236"/>
                                <Setter Property="Foreground" Value="#00C2A8"/>
                                <Setter TargetName="SubMenuArrow" Property="Fill" Value="#00C2A8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3A4A5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#9AAEBF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="1">
                            <ContentPresenter x:Name="HeaderHost"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A2E45"/>
                                <Setter Property="Foreground" Value="#E2EAF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#6B8299"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="6,6,8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="HeaderBorder"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Margin="2,1,2,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>


                                    <ToggleButton Grid.Column="0"
                                                  x:Name="Expander"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="16">
                                                    <Path x:Name="Arrow"
                                                          Data="M 4 6 L 8 10 L 4 14 Z"
                                                          Fill="#6B8299"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90" CenterX="6" CenterY="10"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="#E2EAF3"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <ContentPresenter Grid.Column="1"
                                                      x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="20,0,0,0"
                                            Visibility="Collapsed"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#1A2E45"/>
                                <Setter Property="Foreground" Value="#E2EAF3"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#0E2236"/>
                                <Setter Property="Foreground" Value="#00C2A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TreeSubItemStyle" TargetType="TreeViewItem" BasedOn="{StaticResource TreeItemStyle}">
            <Setter Property="Foreground" Value="#9AAEBF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="6,5,8,5"/>
        </Style>


        <Style TargetType="Separator">
            <Setter Property="Background" Value="#1E3048"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,4"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0"
                Background="#0D1720"
                BorderBrush="#1E3048"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0">
                    <Border Background="#00C2A8"
                            CornerRadius="6"
                            Width="22" Height="22"
                            Margin="0,0,8,0">
                        <TextBlock Text="🏥" FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="MediClinic"
                               Foreground="#E2EAF3"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>


                <Border Grid.Column="1" Width="1"
                        Background="#1E3048" Margin="0,6"/>


                <Menu Grid.Column="2"
                      VerticalAlignment="Center"
                      Margin="8,0">

                    <MenuItem Header="Hệ thống">
                        <MenuItem Header="🔑  Đổi mật khẩu" Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="👤  Thông tin tài khoản" Style="{StaticResource SubMenuItemStyle}"/>
                        <Separator/>
                        <MenuItem Header="🚪  Đăng xuất" x:Name="MenuDangXuat" Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>

                    <MenuItem Header="Danh mục">
                        <MenuItem Header="🩺  Bác sĩ" x:Name="MenuBacSi" Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="💊  Thuốc" x:Name="MenuThuoc" Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="🏷️  Loại dịch vụ" Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="🏠  Phòng khám" Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>

                    <MenuItem Header="Báo cáo">
                        <MenuItem Header="💰  Doanh thu theo ngày" Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="📊  Thống kê bệnh nhân" Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="💊  Tồn kho thuốc" Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>

                    <MenuItem Header="Trợ giúp">
                        <MenuItem Header="📖  Hướng dẫn sử dụng" Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="ℹ️  Về phần mềm" Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>
                </Menu>


                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">

                    <TextBlock x:Name="TxtClock"
                               Text="{Binding ThoiGianHienTai}"
                               Foreground="#6B8299"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>


                    <Border Background="#1A2E45"
                            BorderBrush="#1E3048"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="5,4,10,4"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="22" Height="22"
                                    CornerRadius="11"
                                    Margin="0,0,7,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00C2A8" Offset="0"/>
                                        <GradientStop Color="#0A8F7C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="BS"
                                           Foreground="White"
                                           FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TxtUserName"
                                       Text="Bác sĩ Minh"
                                       Foreground="#E2EAF3"
                                       FontFamily="Segoe UI"
                                       FontSize="12" FontWeight="Medium"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>


        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            
            <Border Grid.Column="0"
                    Background="#111D2B"
                    BorderBrush="#1E3048"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="8,12,8,8">


                        <TextBlock Text="TỔNG QUAN"
                                   Foreground="#6B8299"
                                   FontFamily="Segoe UI"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="8,0,0,4"/>

                        <TreeView Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource TreeItemStyle}">
                            <TreeViewItem x:Name="TreeDashboard">
                                <TreeViewItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Dashboard"
                                                   FontFamily="Segoe UI" FontSize="12.5"
                                                   FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </TreeViewItem.Header>
                            </TreeViewItem>
                        </TreeView>


                        <TextBlock Text="NGHIỆP VỤ"
                                   Foreground="#6B8299"
                                   FontFamily="Segoe UI"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="8,16,0,4"/>

                        <TreeView Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource TreeItemStyle}">


                            <TreeViewItem x:Name="TreeBenhNhan" IsExpanded="True">
                                <TreeViewItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="Bệnh nhân"
                                                       FontFamily="Segoe UI" FontSize="12.5"
                                                       FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="#00C2A8"
                                                CornerRadius="10" Padding="6,1">
                                            <TextBlock Text="128" Foreground="White"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </TreeViewItem.Header>
                                <TreeViewItem x:Name="TreeBenhNhan_DanhSach" 
                                              Header="Danh sách"
                                              Selected="TreeItem_Selected"
                                              Style="{StaticResource TreeSubItemStyle}"/>
                                <TreeViewItem x:Name="TreeBenhNhan_HoSo" 
                                              Header="Hồ sơ khám"
                                              Style="{StaticResource TreeSubItemStyle}"
                                              Selected="TreeItem_HoSoKham_Selected"/>
                            </TreeViewItem>


                            <TreeViewItem x:Name="TreeLichHen" IsExpanded="True">
                                <TreeViewItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📅" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="Lịch hẹn"
                                                       FontFamily="Segoe UI" FontSize="12.5"
                                                       FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="#F0A500"
                                                CornerRadius="10" Padding="6,1">
                                            <TextBlock Text="7" Foreground="White"
                                                       FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </TreeViewItem.Header>
                                <TreeViewItem x:Name="TreeLichHen_Xem" 
                                              Header="Xem lịch"
                                              Style="{StaticResource TreeSubItemStyle}"/>
                                <TreeViewItem x:Name="TreeLichHen_DatMoi" 
                                              Header="Đặt lịch mới"
                                              Style="{StaticResource TreeSubItemStyle}"/>
                            </TreeViewItem>


                            <TreeViewItem x:Name="TreeBacSi">
                                <TreeViewItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🩺" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Bác sĩ"
                                                   FontFamily="Segoe UI" FontSize="12.5"
                                                   FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </TreeViewItem.Header>
                                <TreeViewItem x:Name="TreeBacSi_DanhSach" 
                                              Header="Danh sách"
                                              Style="{StaticResource TreeSubItemStyle}"/>
                                <TreeViewItem x:Name="TreeBacSi_LichLamViec" 
                                              Header="Lịch làm việc"
                                              Style="{StaticResource TreeSubItemStyle}"/>
                            </TreeViewItem>


                            <TreeViewItem x:Name="TreeThuoc">
                                <TreeViewItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💊" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Thuốc &amp; Kho dược"
                                                   FontFamily="Segoe UI" FontSize="12.5"
                                                   FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </TreeViewItem.Header>
                                <TreeViewItem x:Name="TreeThuoc_DanhSach" 
                                              Header="Danh sách thuốc"
                                              Style="{StaticResource TreeSubItemStyle}"/>
                                <TreeViewItem x:Name="TreeThuoc_NhapKho"  
                                              Header="Nhập kho"
                                              Style="{StaticResource TreeSubItemStyle}"/>
                            </TreeViewItem>

                        </TreeView>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                
                <Border Grid.Row="0"
                        Background="#0F1923"
                        BorderBrush="#1E3048"
                        BorderThickness="0,0,0,1"
                        Padding="24,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock x:Name="TxtBreadcrumb1"
                                           Text="Tổng quan"
                                           Foreground="#6B8299"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="›"
                                           Foreground="#6B8299"
                                           FontSize="12" Opacity="0.4"
                                           Margin="0,0,6,0"/>
                                <TextBlock x:Name="TxtBreadcrumb2"
                                           Text="Dashboard"
                                           Foreground="#E2EAF3"
                                           FontFamily="Segoe UI" FontSize="12"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="TxtPageTitle"
                                       Text="{Binding TieuDeTrang}"
                                       Foreground="#E2EAF3"
                                       FontFamily="Segoe UI"
                                       FontSize="18" FontWeight="Bold"/>
                        </StackPanel>

                        
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnExport"
                                    Content="📤  Xuất báo cáo"
                                    Style="{StaticResource BtnGhost}"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="BtnAddNew"
                                    Content="＋  Đặt lịch mới"
                                    Style="{StaticResource BtnPrimary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                
                <ContentControl x:Name="MainContentArea"
                                Content="{Binding ViewHienTai}"
                                Grid.Row="1"
                                Background="#0F1923"/>
            </Grid>
        </Grid>


        <Border Grid.Row="2"
                Background="#0D1720"
                BorderBrush="#1E3048"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    <Ellipse Width="6" Height="6" Fill="#3ECF8E" Margin="0,0,5,0"/>
                    <TextBlock Text="Đã kết nối CSDL"
                               Foreground="#6B8299"
                               FontFamily="Segoe UI" FontSize="11"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="TxtStatusUser"
                           Text="👤 Bác sĩ Minh  ·  Phân quyền: Admin"
                           Foreground="#6B8299"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3"
                           Text="Phiên bản 1.0.0"
                           Foreground="#6B8299"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>