<UserControl x:Class="DoAn_QuanLyBenhVien.Views.UC_HoSoKham"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DoAn_QuanLyBenhVien.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#10B981"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1E293B"/>
            <Setter Property="AlternatingRowBackground" Value="#1E293B"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#334155"/>
                        <Setter Property="Foreground" Value="#94A3B8"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#475569"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,10,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#10B981"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ButtonTab2Style" TargetType="Button">
            <Setter Property="Background" Value="#474D57"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                        CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#575E69"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Background="#0F172A">
        <Grid Margin="20">
            <TabControl Background="Transparent" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="Chưa chẩn đoán" Style="{StaticResource ModernTabItem}">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#1E293B" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="THÔNG TIN CHI TIẾT" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>

                                    <TextBlock Text="Họ và Tên" Foreground="#94A3B8" FontSize="12"/>
                                    <TextBox Text="{Binding BNDangChonVaoKham.TenBenhNhan, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Style="{StaticResource DarkTextBox}" Margin="0,5,0,10"/>

                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,5,0">
                                            <TextBlock Text="Giới tính" Foreground="#94A3B8" FontSize="12"/>
                                            <TextBox Text="{Binding BNDangChonVaoKham.GioiTinh, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Style="{StaticResource DarkTextBox}" Margin="0,5,0,10"/>
                                        </StackPanel>
                                        <StackPanel Margin="5,0,0,0">
                                            <TextBlock Text="Ngày sinh" Foreground="#94A3B8" FontSize="12"/>
                                            <TextBox Text="{Binding BNDangChonVaoKham.NgaySinh, StringFormat='dd/MM/yyyy', Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Style="{StaticResource DarkTextBox}" Margin="0,5,0,10"/>
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Text="Số điện thoại" Foreground="#94A3B8" FontSize="12"/>
                                    <TextBox Text="{Binding BNDangChonVaoKham.SoDienThoai, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Style="{StaticResource DarkTextBox}" Margin="0,5,0,10"/>

                                    <TextBlock Text="Tiền sử bệnh lý" Foreground="#94A3B8" FontSize="12"/>
                                    <TextBox Text="{Binding BNDangChonVaoKham.TienSuBenhLy, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Style="{StaticResource DarkTextBox}" Height="50" TextWrapping="Wrap" Margin="0,5"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="#1E293B" CornerRadius="12" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="DANH SÁCH CHỜ" Foreground="White" FontWeight="Bold" Margin="5,0,0,10"/>
                                    <DataGrid Grid.Row="1" 
                                              Style="{StaticResource DarkDataGrid}" AutoGenerateColumns="False" IsReadOnly="True"
                                              Height="300" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ItemsSource="{Binding DSBNChuaKham}" SelectedItem="{Binding BNDangChonVaoKham}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Mã BN" Binding="{Binding MaBenhNhan}" Width="80"/>
                                            <DataGridTextColumn Header="Họ Tên" Binding="{Binding TenBenhNhan}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1" Margin="20,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="NỘI DUNG KHÁM &amp; CHUẨN ĐOÁN" Foreground="White" FontWeight="Bold" Margin="0,0,0,15"/>
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Triệu chứng" Foreground="#94A3B8" FontSize="12"/>
                                                <TextBlock Text="*" Foreground="#EF4444" FontSize="13" Margin="3 0 0 0"/>
                                            </StackPanel>
                                            <TextBox Style="{StaticResource DarkTextBox}" Height="80" TextWrapping="Wrap" Margin="0,5" Text="{Binding TrieuChung}"/>
                                        </StackPanel>
                                        <StackPanel Margin="10,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Chẩn đoán" Foreground="#94A3B8" FontSize="12"/>
                                                <TextBlock Text="*" Foreground="#EF4444" FontSize="13" Margin="3 0 0 0"/>
                                            </StackPanel>
                                            <TextBox Text="{Binding ChuanDoan}" Style="{StaticResource DarkTextBox}" Height="80" TextWrapping="Wrap" Margin="0,5"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="#1E293B" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="CHỈ ĐỊNH DỊCH VỤ CẬN LÂM SÀNG" Foreground="White" FontWeight="Bold" Margin="0,0,0,15"/>
                                        <TextBlock Text="*" Foreground="#EF4444" FontSize="13" Margin="5 0 0 0"/>
                                    </StackPanel>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding DSDichVu}" 
                                            Style="{StaticResource DarkDataGrid}" AutoGenerateColumns="False"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto" CanUserAddRows="False"
                                            IsReadOnly="False" SelectionMode="Single" Background="Transparent">

                                        <DataGrid.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
                                        </DataGrid.Resources>

                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Binding="{Binding IsSelected}" Header="Chọn" Width="60"/>
                                            <DataGridTextColumn Header="Tên Dịch Vụ" Binding="{Binding TenDichVu}" Width="*"/>
                                            <DataGridTextColumn Header="Giá Tiền (VNĐ)" Binding="{Binding GiaTien, StringFormat={}{0:N0}}" Width="150"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                <Button Content="HỦY BỎ" Command="{Binding LenhHuy}" Width="120" Height="40" Margin="0,0,10,0" 
                                        Background="#475569" Foreground="White" BorderThickness="0"/>
                                <Button Content="LƯU HỒ SƠ" Command="{Binding LenhLuu}" Width="150" Height="40" 
                                        Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Đã chẩn đoán" Style="{StaticResource ModernTabItem}" Height="41" VerticalAlignment="Top">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,0,10"
                                Visibility="Visible">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="NỘI DUNG CHI TIẾT" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>

                                    <TextBlock Text="Triệu chứng" Foreground="#94A3B8" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedLichSu.TrieuChung}" Style="{StaticResource DarkTextBox}" 
                                            Height="60" Margin="0,5" IsEnabled="{Binding IsSua}" TextWrapping="Wrap" AcceptsReturn="True"/>

                                    <TextBlock Text="Chẩn đoán" Foreground="#94A3B8" FontSize="11" Margin="0,5,0,0"/>
                                    <TextBox Text="{Binding SelectedLichSu.ChuanDoan}" Style="{StaticResource DarkTextBox}" 
                                            Height="60" Margin="0,5" IsEnabled="{Binding IsSua}" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="DỊCH VỤ ĐÃ THỰC HIỆN" Foreground="White" FontWeight="Bold" Margin="0,0,0,15" FontSize="14"/>

                                    <Border Background="#334155" CornerRadius="8" Padding="5" Height="165" VerticalAlignment="Bottom">
                                        <DataGrid ItemsSource="{Binding DSDichVu}" 
                                            Style="{StaticResource DarkDataGrid}" AutoGenerateColumns="False" 
                                            IsReadOnly="False" CanUserAddRows="False" HeadersVisibility="Column"
                                            Background="Transparent" SelectionMode="Single">

                                            <DataGrid.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
                                            </DataGrid.Resources>

                                            <DataGrid.CellStyle>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.CellStyle>

                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="Chọn" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="60">
                                                    <DataGridCheckBoxColumn.ElementStyle>
                                                        <Style TargetType="CheckBox">
                                                            <Setter Property="IsEnabled" Value="{Binding DataContext.IsSua, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                        </Style>
                                                    </DataGridCheckBoxColumn.ElementStyle>
                                                </DataGridCheckBoxColumn>

                                                <DataGridTextColumn Header="Tên Dịch Vụ" Binding="{Binding TenDichVu}" IsReadOnly="True" Width="*"/>
                                                <DataGridTextColumn Header="Giá Tiền" Binding="{Binding GiaTien, StringFormat={}{0:N0}}" IsReadOnly="True" Width="120"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
                            <Button Content="SỬA" Command="{Binding LenhSuaLichSu}" Width="100" Height="35" Style="{StaticResource ButtonTab2Style}"
                                    Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="5,0" BorderThickness="0"/>

                            <Button Content="XÓA" Command="{Binding LenhXoaLichSu}" Width="100" Height="35" Style="{StaticResource ButtonTab2Style}"
                                    Background="#EF4444" Foreground="White" FontWeight="Bold" Margin="5,0" BorderThickness="0"/>

                            <Button Content="LƯU" Command="{Binding LenhLuuLichSu}" Width="100" Height="35" Style="{StaticResource ButtonTab2Style}"
                                    Background="#10B981" Foreground="White" FontWeight="Bold" Margin="5,0" BorderThickness="0"
                                    IsEnabled="{Binding IsSua}"/>
                        </StackPanel>

                        <Border Grid.Row="2" Background="#1E293B" CornerRadius="12" Padding="10">
                            <DataGrid ItemsSource="{Binding DSLichSuKham}" SelectedItem="{Binding SelectedLichSu}"
                                    Style="{StaticResource DarkDataGrid}" AutoGenerateColumns="False" IsReadOnly="True"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ngày Khám" Binding="{Binding NgayKham, StringFormat='dd/MM/yyyy'}" Width="120"/>
                                    <DataGridTextColumn Header="Mã BN" Binding="{Binding BN.MaBenhNhan}" Width="100"/>
                                    <DataGridTextColumn Header="Họ Tên" Binding="{Binding BN.TenBenhNhan}" Width="*"/>
                                    <DataGridTextColumn Header="Triệu Chứng" Binding="{Binding TrieuChung}" Width="*"/>
                                    <DataGridTextColumn Header="Chẩn Đoán" Binding="{Binding ChuanDoan}" Width="*"/>
                                    <DataGridTemplateColumn Header="Dịch Vụ" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding DichVuDaDung}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding TenDichVu}" Foreground="White" FontSize="11"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>
